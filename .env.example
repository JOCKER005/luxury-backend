# ─── Mercado Pago ───────────────────────────────────────────────────────────
# Tu Access Token de Mercado Pago (Producción)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx

# Secret del webhook (encontrarlo en MP Developers → Webhooks → tu webhook → Secret key)
# Dejar vacío para deshabilitar verificación de firma (solo en desarrollo)
MP_WEBHOOK_SECRET=

# ─── Base de datos ──────────────────────────────────────────────────────────
# SQLite local (desarrollo):
DATABASE_URL=sqlite:///./luxe.db
# PostgreSQL Railway (producción) — Railway lo provee automáticamente:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Seguridad Admin ────────────────────────────────────────────────────────
# Cambiá esto por una clave secreta fuerte en producción
ADMIN_SECRET=Pach1!!

# ─── CORS ───────────────────────────────────────────────────────────────────
# URLs del frontend separadas por coma. En desarrollo dejar así.
# En producción reemplazar con tu URL real de Vercel/Netlify.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
# Ejemplo producción:
# ALLOWED_ORIGINS=https://luxe-joyeria.vercel.app,https://www.luxejoyeria.com
